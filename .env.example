PUBLIC_SITE_URL=https://your-domain.com
PUBLIC_SITE_NAME=小七的 AI 知识花园
PUBLIC_SITE_DESCRIPTION=小七的 AI 驱动个人数字花园，沉淀博客、笔记、项目和工具箱。
PUBLIC_AUTHOR_NAME=小七

# Hot-swappable OpenAI-compatible LLM gateway.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-key
LLM_MODEL=gpt-5.2
LLM_SMALL_MODEL=gpt-5.2-mini
LLM_IMAGE_MODEL=gpt-image-1.5
LLM_TIMEOUT_SECONDS=120

# Content automation.
AI_INPUT_DIR=drafts
AI_OUTPUT_DIR=src/content/blog
AI_LOCALIZE_LANGS=en,zh,ja
AI_MAX_RETRIES=6
AI_RATE_LIMIT_RPM=30

# Optional GitHub automation.
GITHUB_TOKEN=
GITHUB_REPOSITORY=
GITHUB_ISSUES_LABEL=blog-draft