---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/lib/site";
---

<BaseLayout title="创作台" description={`快速添加${site.name}的博客、笔记、项目和工具箱内容。`}>
  <section class="container studio-shell py-8" data-pagefind-ignore>
    <header class="studio-head">
      <div>
        <p class="studio-eyebrow">本地内容创作台</p>
        <h1>快捷添加内容</h1>
        <p>在网页里创建博客、笔记、项目和工具箱条目。本地写入服务在线时可直接保存到项目；否则可以下载 MDX 文件。</p>
      </div>
      <div class="studio-status" data-status="checking">
        <span aria-hidden="true"></span>
        <strong id="writer-status">检查写入服务</strong>
      </div>
    </header>

    <div class="studio-grid">
      <form class="studio-form surface" id="studio-form">
        <fieldset class="studio-fieldset">
          <legend>内容类型</legend>
          <div class="studio-segments" role="radiogroup" aria-label="内容类型">
            <label>
              <input type="radio" name="collection" value="notes" checked />
              <span>笔记</span>
            </label>
            <label>
              <input type="radio" name="collection" value="blog" />
              <span>博客</span>
            </label>
            <label>
              <input type="radio" name="collection" value="projects" />
              <span>项目</span>
            </label>
            <label>
              <input type="radio" name="collection" value="tools" />
              <span>工具箱</span>
            </label>
          </div>
        </fieldset>

        <div class="studio-row">
          <label>
            <span>标题</span>
            <input id="title" name="title" required placeholder="例如：Cherry Studio 启动问题排查" />
          </label>
          <label>
            <span>日期</span>
            <input id="date" name="date" type="date" />
          </label>
        </div>

        <label>
          <span>描述</span>
          <input id="description" name="description" placeholder="用于列表卡片和 SEO 描述" />
        </label>

        <div class="studio-row">
          <label>
            <span>标签</span>
            <input id="tags" name="tags" placeholder="Windows,排障,AI" />
          </label>
          <label>
            <span>分类</span>
            <input id="category" name="category" placeholder="短笔记" />
          </label>
        </div>

        <div class="studio-row">
          <label>
            <span>Slug</span>
            <input id="slug" name="slug" placeholder="留空自动生成" />
          </label>
          <label>
            <span>状态</span>
            <select id="status" name="status">
              <option value="building">构建中</option>
              <option value="planning">计划中</option>
              <option value="maintained">维护中</option>
              <option value="archived">已归档</option>
            </select>
          </label>
        </div>

        <div class="studio-row studio-project-fields" hidden>
          <label>
            <span>技术栈</span>
            <input id="stack" name="stack" placeholder="Astro,TypeScript,Pagefind" />
          </label>
          <label>
            <span>仓库地址</span>
            <input id="repo" name="repo" type="url" placeholder="https://github.com/..." />
          </label>
        </div>

        <div class="studio-row studio-project-fields" hidden>
          <label>
            <span>演示地址</span>
            <input id="demo" name="demo" type="url" placeholder="https://..." />
          </label>
        </div>

        <div class="studio-row studio-tool-fields" hidden>
          <label>
            <span>工具链接</span>
            <input id="link" name="link" type="url" placeholder="https://..." />
          </label>
        </div>

        <label>
          <span>摘要</span>
          <textarea id="summary" name="summary" rows="3" placeholder="给未来的自己看的短摘要"></textarea>
        </label>

        <label>
          <span>正文</span>
          <textarea id="body" name="body" rows="14" placeholder="写下内容，支持 Markdown/MDX"></textarea>
        </label>

        <div class="studio-switches">
          <label>
            <input id="draft" name="draft" type="checkbox" />
            <span>保存为草稿</span>
          </label>
          <label>
            <input id="featured" name="featured" type="checkbox" />
            <span>设为精选</span>
          </label>
        </div>

        <div class="studio-actions">
          <button class="button-primary" type="submit" id="save-button">保存到项目</button>
          <button class="button-secondary" type="button" id="download-button">下载 MDX</button>
          <button class="button-secondary" type="button" id="copy-button">复制 MDX</button>
        </div>
        <p class="studio-message" id="studio-message" role="status"></p>
      </form>

      <aside class="studio-preview surface" aria-label="MDX 预览">
        <div class="studio-preview__head">
          <div>
            <span>实时预览</span>
            <strong id="preview-name">未命名.mdx</strong>
          </div>
          <button class="button-secondary" type="button" id="refresh-preview">刷新</button>
        </div>
        <pre><code id="mdx-preview"></code></pre>
      </aside>
    </div>
  </section>

  <script>
    const writerUrl = "http://127.0.0.1:8787";
    const form = document.querySelector("#studio-form");
    const message = document.querySelector("#studio-message");
    const statusBox = document.querySelector(".studio-status");
    const statusText = document.querySelector("#writer-status");
    const preview = document.querySelector("#mdx-preview");
    const previewName = document.querySelector("#preview-name");
    const saveButton = document.querySelector("#save-button");
    const projectFields = document.querySelectorAll(".studio-project-fields");
    const toolFields = document.querySelectorAll(".studio-tool-fields");

    const collectionDefaults = {
      blog: {
        category: "长期写作",
        tags: "写作",
        body: "## 背景\n\n\n## 正文\n\n\n## 结论\n\n"
      },
      notes: {
        category: "短笔记",
        tags: "笔记",
        body: "## 记录\n\n\n## 处理\n\n\n## 以后再看\n\n"
      },
      projects: {
        category: "项目",
        tags: "项目",
        body: "## 目标\n\n\n## 技术栈\n\n\n## 进展\n\n\n## 复盘\n\n"
      },
      tools: {
        category: "工具箱",
        tags: "工具箱",
        body: "## 用途\n\n\n## 安装和位置\n\n\n## 常用操作\n\n"
      }
    };

    let writerOnline = false;
    let latestMdx = "";
    let latestFileName = "未命名.mdx";

    const today = () => new Date().toISOString().slice(0, 10);

    function setMessage(text, tone = "muted") {
      message.textContent = text;
      message.dataset.tone = tone;
    }

    function getCollection() {
      return new FormData(form).get("collection");
    }

    function getPayload() {
      const data = new FormData(form);
      return {
        collection: data.get("collection"),
        title: data.get("title"),
        date: data.get("date") || today(),
        description: data.get("description"),
        tags: data.get("tags"),
        category: data.get("category"),
        slug: data.get("slug"),
        summary: data.get("summary"),
        body: data.get("body"),
        draft: data.get("draft") === "on",
        featured: data.get("featured") === "on",
        status: data.get("status"),
        stack: data.get("stack"),
        repo: data.get("repo"),
        demo: data.get("demo"),
        link: data.get("link")
      };
    }

    function slugify(value, fallback = "content") {
      const ascii = String(value || "")
        .normalize("NFKD")
        .replace(/[\u0300-\u036f]/g, "")
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "")
        .replace(/-{2,}/g, "-");
      return ascii || `${fallback}-${Math.random().toString(16).slice(2, 10)}`;
    }

    function quote(value) {
      return `"${String(value || "").replace(/\\/g, "\\\\").replace(/"/g, '\\"')}"`;
    }

    function tags(value, fallback) {
      const items = String(value || fallback)
        .split(/[,，]/)
        .map((item) => item.trim())
        .filter(Boolean);
      return `[${items.map(quote).join(", ")}]`;
    }

    function localMdx(payload) {
      const typeMap = { blog: "blog", notes: "note", projects: "project", tools: "tool" };
      const defaultMap = collectionDefaults[payload.collection] || collectionDefaults.notes;
      const title = payload.title || "未命名内容";
      const date = payload.date || today();
      const lines = [
        "---",
        `title: ${quote(title)}`,
        `description: ${quote(payload.description || `${title} 的记录和整理。`)}`,
        `date: ${date}`,
        `tags: ${tags(payload.tags, defaultMap.tags)}`,
        `category: ${quote(payload.category || defaultMap.category)}`,
        `draft: ${payload.draft ? "true" : "false"}`,
        `featured: ${payload.featured ? "true" : "false"}`,
        `summary: ${quote(payload.summary || `${title} 的要点摘要。`)}`,
        "language: zh",
        `type: ${quote(typeMap[payload.collection] || "note")}`
      ];

      if (payload.collection === "projects") {
        lines.push(`status: ${payload.status || "building"}`);
        lines.push(`stack: ${tags(payload.stack, "Astro,TypeScript")}`);
        if (payload.repo) lines.push(`repo: ${quote(payload.repo)}`);
        if (payload.demo) lines.push(`demo: ${quote(payload.demo)}`);
      }

      if (payload.collection === "tools" && payload.link) {
        lines.push(`link: ${quote(payload.link)}`);
      }

      lines.push("---");
      return `${lines.join("\n")}\n\n${payload.body || defaultMap.body}\n`;
    }

    async function checkWriter() {
      try {
        const response = await fetch(`${writerUrl}/health`, { cache: "no-store" });
        writerOnline = response.ok;
      } catch {
        writerOnline = false;
      }

      statusBox.dataset.status = writerOnline ? "online" : "offline";
      statusText.textContent = writerOnline ? "本地写入已连接" : "仅下载/复制";
      saveButton.disabled = !writerOnline;
      saveButton.title = writerOnline ? "保存到 src/content" : "先运行 npm run studio:server";
    }

    async function refreshPreview() {
      const payload = getPayload();
      latestFileName = `${payload.date || today()}-${slugify(payload.slug || payload.title, payload.collection)}.mdx`;

      if (writerOnline && payload.title) {
        try {
          const response = await fetch(`${writerUrl}/preview`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });
          const data = await response.json();
          if (data.ok) {
            latestMdx = data.content;
            latestFileName = data.fileName;
          } else {
            latestMdx = localMdx(payload);
          }
        } catch {
          latestMdx = localMdx(payload);
        }
      } else {
        latestMdx = localMdx(payload);
      }

      preview.textContent = latestMdx;
      previewName.textContent = latestFileName;
    }

    function syncCollectionFields(forceTemplate = false) {
      const collection = getCollection();
      const defaults = collectionDefaults[collection] || collectionDefaults.notes;
      projectFields.forEach((item) => (item.hidden = collection !== "projects"));
      toolFields.forEach((item) => (item.hidden = collection !== "tools"));

      if (forceTemplate || !form.category.value) form.category.value = defaults.category;
      if (forceTemplate || !form.tags.value) form.tags.value = defaults.tags;
      if (forceTemplate || !form.body.value) form.body.value = defaults.body;
      refreshPreview();
    }

    function applyInitialTypeFromUrl() {
      const params = new URLSearchParams(window.location.search);
      const type = params.get("type") || params.get("collection");
      const allowed = ["blog", "notes", "projects", "tools"];
      if (!allowed.includes(type)) return;
      const input = form.querySelector(`input[name="collection"][value="${type}"]`);
      if (input) {
        input.checked = true;
        syncCollectionFields(true);
      }
    }

    function downloadMdx() {
      const blob = new Blob([latestMdx], { type: "text/markdown;charset=utf-8" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = latestFileName;
      link.click();
      URL.revokeObjectURL(url);
      setMessage(`已生成下载文件：${latestFileName}`, "success");
    }

    async function copyMdx() {
      await navigator.clipboard.writeText(latestMdx);
      setMessage("MDX 已复制到剪贴板。", "success");
    }

    form.date.value = today();
    syncCollectionFields(true);
    applyInitialTypeFromUrl();
    checkWriter().then(refreshPreview);
    setInterval(checkWriter, 5000);

    form.addEventListener("input", () => refreshPreview());
    form.addEventListener("change", (event) => {
      if (event.target?.name === "collection") {
        syncCollectionFields(true);
      } else {
        refreshPreview();
      }
    });

    document.querySelector("#refresh-preview").addEventListener("click", refreshPreview);
    document.querySelector("#download-button").addEventListener("click", () => {
      refreshPreview().then(downloadMdx);
    });
    document.querySelector("#copy-button").addEventListener("click", () => {
      refreshPreview().then(copyMdx);
    });

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!writerOnline) {
        setMessage("本地写入服务未连接。请运行 npm run studio:server，或先下载 MDX。", "warning");
        return;
      }

      try {
        const response = await fetch(`${writerUrl}/content`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(getPayload())
        });
        const data = await response.json();
        if (!response.ok || !data.ok) {
          throw new Error(data.message || "保存失败");
        }
        latestFileName = data.fileName;
        previewName.textContent = latestFileName;
        setMessage(`已保存：${data.filePath}`, "success");
      } catch (error) {
        setMessage(error instanceof Error ? error.message : String(error), "warning");
      }
    });
  </script>
</BaseLayout>
