---
import { getCollection, render } from "astro:content";
import { Icon } from "astro-icon/components";
import Markdown from "@/components/common/Markdown.astro";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { formatDateToYYYYMMDD } from "@/utils/date-utils";
import { removeFileExtension, url } from "@/utils/url-utils";

export async function getStaticPaths() {
	const noteEntries = await getCollection("notes", ({ data }) => {
		return import.meta.env.PROD ? data.draft !== true : true;
	});

	return noteEntries.map((entry) => ({
		params: { slug: removeFileExtension(entry.id) },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<MainGridLayout
  title={entry.data.title}
  description={entry.data.description || entry.data.title}
  headings={headings}
>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative mb-4">
    <article class="card-base z-10 px-6 md:px-9 pt-6 pb-7 relative w-full">
      <a
        href={url("/notes/")}
        class="inline-flex items-center gap-1.5 text-sm font-medium text-neutral-500 dark:text-neutral-400 hover:text-(--primary) transition-colors mb-4"
      >
        <Icon is:inline name="material-symbols:chevron-left-rounded" class="text-lg" />
        随手记
      </a>

      <div class="relative">
        <h1 class="transition w-full block font-bold mb-3 text-3xl md:text-[2.25rem]/[2.75rem] text-black/90 dark:text-white/90 md:before:w-1 before:h-5 before:rounded-md before:bg-(--primary) before:absolute before:top-3 before:-left-4.5">
          {entry.data.title}
        </h1>
      </div>

      <div class="flex flex-wrap items-center gap-4 text-sm text-neutral-500 dark:text-neutral-400 mb-6">
        <div class="flex items-center gap-1.5">
          <Icon is:inline name="material-symbols:calendar-month-outline-rounded" />
          <time>{formatDateToYYYYMMDD(entry.data.published)}</time>
        </div>
        {entry.data.updated && (
          <div class="flex items-center gap-1.5">
            <Icon is:inline name="material-symbols:update-rounded" />
            <time>{formatDateToYYYYMMDD(entry.data.updated)}</time>
          </div>
        )}
        {entry.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {entry.data.tags.map((tag) => (
              <span class="rounded-md bg-(--btn-regular-bg) px-2 py-1 text-xs font-medium text-(--btn-content)">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </div>

      <Markdown class="mt-2">
        <Content />
      </Markdown>
    </article>
  </div>
</MainGridLayout>
