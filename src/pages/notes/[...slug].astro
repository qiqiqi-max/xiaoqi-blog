---
import ArticleLayout from "@/layouts/ArticleLayout.astro";
import { getPublishedNotes } from "@/lib/content";
import { render } from "astro:content";

export async function getStaticPaths() {
  const notes = await getPublishedNotes();
  return notes.map((note) => ({ params: { slug: note.id }, props: { note } }));
}

const { note } = Astro.props;
const { Content, headings } = await render(note);
---

<ArticleLayout {...note.data} body={note.body} headings={headings} section="笔记" type="note">
  <Content />
</ArticleLayout>
