---
import CollectionOverview from "@/components/CollectionOverview.astro";
import EntryCard from "@/components/EntryCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPublishedNotes } from "@/lib/content";

const notes = await getPublishedNotes();
const tagCount = new Set(notes.flatMap((note) => note.data.tags)).size;
const latestNote = notes[0]?.data.title ?? "暂无笔记";
---

<BaseLayout title="笔记" description="学习碎片、排障记录和短笔记。">
  <section class="container">
    <header class="page-head">
      <div>
        <h1>笔记</h1>
        <p>不必完美，但要可查。这里放学习碎片、软件排障、命令记录和临时想法。</p>
      </div>
      <div class="page-actions">
        <a class="button-primary" href="/studio?type=notes">添加笔记</a>
        <a class="button-secondary" href="/search">搜索笔记</a>
      </div>
    </header>
    <CollectionOverview
      eyebrow="快速记录区"
      title="把日常问题和临时想法变成可检索资产"
      description="笔记模块用来记录排障过程、命令片段、软件迁移、配置问题和不适合写成长文的想法。它追求可查、可复用、低成本更新。"
      ctaHref="/tags"
      ctaLabel="查看标签"
      metrics={[
        { label: "笔记数量", value: `${notes.length} 条`, note: "短记录和排障" },
        { label: "最新笔记", value: latestNote, note: "最近一次沉淀" },
        { label: "标签覆盖", value: `${tagCount} 个`, note: "跨主题检索" }
      ]}
    />
    <div class="content-grid py-8">
      {notes.map((note) => (
        <EntryCard href={`/notes/${note.id}`} title={note.data.title} description={note.data.description} date={note.data.date} tags={note.data.tags} />
      ))}
    </div>
  </section>
</BaseLayout>
