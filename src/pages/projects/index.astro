---
import CollectionOverview from "@/components/CollectionOverview.astro";
import EntryCard from "@/components/EntryCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPublishedProjects } from "@/lib/content";

const projects = await getPublishedProjects();
const maintainedCount = projects.filter((project) => project.data.status === "maintained").length;
const buildingCount = projects.filter((project) => project.data.status === "building").length;
const stackCount = new Set(projects.flatMap((project) => project.data.stack)).size;
---

<BaseLayout title="项目" description="个人项目、工具和长期作品档案。">
  <section class="container">
    <header class="page-head">
      <div>
        <h1>项目</h1>
        <p>每一个项目都记录目标、技术栈、状态和复盘，形成可展示的长期作品集。</p>
      </div>
      <div class="page-actions">
        <a class="button-primary" href="/studio?type=projects">添加项目</a>
        <a class="button-secondary" href="/tags">浏览标签</a>
      </div>
    </header>
    <CollectionOverview
      eyebrow="作品档案区"
      title="把想法、构建过程和成果放进同一个项目档案"
      description="项目模块用来记录长期作品、技术实验、自动化工具和公开可展示的成果。每个项目都可以沉淀技术栈、状态、演示地址和复盘。"
      ctaHref="/search"
      ctaLabel="搜索项目"
      metrics={[
        { label: "项目数量", value: `${projects.length} 个`, note: "长期维护对象" },
        { label: "进行中", value: `${buildingCount} 个`, note: "正在构建" },
        { label: "维护中", value: `${maintainedCount} 个`, note: "可持续迭代" },
        { label: "技术栈", value: `${stackCount} 项`, note: "跨项目复用" }
      ]}
    />
    <div class="content-grid py-8">
      {projects.map((project) => (
        <EntryCard href={`/projects/${project.id}`} title={project.data.title} description={project.data.description} date={project.data.date} tags={project.data.stack} />
      ))}
    </div>
  </section>
</BaseLayout>
