---
import ToolPage from "@/components/tools/ToolPage.astro";
---

<ToolPage
	title="时间戳转换"
	description="Unix 时间戳、毫秒时间戳和本地日期时间互相转换。"
	icon="material-symbols:schedule"
>
	<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
		<div class="rounded-lg border border-(--line-divider) bg-(--card-bg) p-4">
			<div class="text-sm text-neutral-500 dark:text-neutral-400">当前秒级时间戳</div>
			<div id="now-seconds" class="mt-2 font-mono text-2xl font-bold text-neutral-900 dark:text-neutral-100">-</div>
		</div>
		<div class="rounded-lg border border-(--line-divider) bg-(--card-bg) p-4">
			<div class="text-sm text-neutral-500 dark:text-neutral-400">当前毫秒时间戳</div>
			<div id="now-ms" class="mt-2 font-mono text-2xl font-bold text-neutral-900 dark:text-neutral-100">-</div>
		</div>
		<div class="rounded-lg border border-(--line-divider) bg-(--card-bg) p-4">
			<div class="text-sm text-neutral-500 dark:text-neutral-400">当前本地时间</div>
			<div id="now-local" class="mt-2 font-mono text-lg font-bold text-neutral-900 dark:text-neutral-100">-</div>
		</div>
	</div>

	<div class="mt-4 grid grid-cols-1 xl:grid-cols-2 gap-4">
		<section class="rounded-lg border border-(--line-divider) bg-(--card-bg) p-4">
			<h2 class="mb-3 text-lg font-bold text-neutral-900 dark:text-neutral-100">时间戳转日期</h2>
			<input id="timestamp-input" class="tool-input" placeholder="输入 10 位秒级或 13 位毫秒级时间戳" />
			<div class="mt-3 flex flex-wrap gap-3">
				<button id="timestamp-convert" class="btn-regular rounded-lg px-4 py-2 font-medium">转换</button>
				<button id="timestamp-fill-now" class="btn-regular rounded-lg px-4 py-2 font-medium">填入当前</button>
			</div>
			<div id="timestamp-result" class="mt-4 rounded-lg bg-(--btn-regular-bg) p-4 text-sm leading-relaxed text-neutral-700 dark:text-neutral-300">
				等待转换。
			</div>
		</section>

		<section class="rounded-lg border border-(--line-divider) bg-(--card-bg) p-4">
			<h2 class="mb-3 text-lg font-bold text-neutral-900 dark:text-neutral-100">日期转时间戳</h2>
			<input id="date-input" type="datetime-local" class="tool-input" />
			<div class="mt-3 flex flex-wrap gap-3">
				<button id="date-convert" class="btn-regular rounded-lg px-4 py-2 font-medium">转换</button>
				<button id="date-fill-now" class="btn-regular rounded-lg px-4 py-2 font-medium">填入当前</button>
			</div>
			<div id="date-result" class="mt-4 rounded-lg bg-(--btn-regular-bg) p-4 text-sm leading-relaxed text-neutral-700 dark:text-neutral-300">
				等待转换。
			</div>
		</section>
	</div>
</ToolPage>

<style>
	.tool-input {
		width: 100%;
		border-radius: 0.75rem;
		border: 1px solid var(--line-divider);
		background: color-mix(in srgb, var(--card-bg) 90%, transparent);
		padding: 0.75rem 1rem;
		font-size: 0.95rem;
		outline: none;
	}
	.tool-input:focus {
		border-color: var(--primary);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 18%, transparent);
	}
</style>

<script>
	const nowSeconds = document.querySelector<HTMLElement>("#now-seconds")!;
	const nowMs = document.querySelector<HTMLElement>("#now-ms")!;
	const nowLocal = document.querySelector<HTMLElement>("#now-local")!;
	const timestampInput = document.querySelector<HTMLInputElement>("#timestamp-input")!;
	const timestampResult = document.querySelector<HTMLElement>("#timestamp-result")!;
	const dateInput = document.querySelector<HTMLInputElement>("#date-input")!;
	const dateResult = document.querySelector<HTMLElement>("#date-result")!;
	const timestampFillNowBtn = document.querySelector<HTMLButtonElement>("#timestamp-fill-now")!;
	const timestampConvertBtn = document.querySelector<HTMLButtonElement>("#timestamp-convert")!;
	const dateFillNowBtn = document.querySelector<HTMLButtonElement>("#date-fill-now")!;
	const dateConvertBtn = document.querySelector<HTMLButtonElement>("#date-convert")!;

	function pad(n: number): string {
		return String(n).padStart(2, "0");
	}

	function toDatetimeLocal(date: Date): string {
		return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}T${pad(date.getHours())}:${pad(date.getMinutes())}:${pad(date.getSeconds())}`;
	}

	function renderNow() {
		const now = new Date();
		nowSeconds.textContent = Math.floor(now.getTime() / 1000).toString();
		nowMs.textContent = now.getTime().toString();
		nowLocal.textContent = now.toLocaleString();
	}

	timestampFillNowBtn.addEventListener("click", () => {
		timestampInput.value = Date.now().toString();
	});
	timestampConvertBtn.addEventListener("click", () => {
		const raw = timestampInput.value.trim();
		if (!/^-?\d+$/.test(raw)) {
			timestampResult.textContent = "请输入纯数字时间戳。";
			return;
		}
		const num = Number(raw);
		const ms = raw.length <= 10 ? num * 1000 : num;
		const date = new Date(ms);
		if (Number.isNaN(date.getTime())) {
			timestampResult.textContent = "无法转换该时间戳。";
			return;
		}
		timestampResult.innerHTML = `本地时间：<strong>${date.toLocaleString()}</strong><br>ISO 时间：<strong>${date.toISOString()}</strong><br>秒级：<strong>${Math.floor(ms / 1000)}</strong><br>毫秒级：<strong>${ms}</strong>`;
	});
	dateFillNowBtn.addEventListener("click", () => {
		dateInput.value = toDatetimeLocal(new Date());
	});
	dateConvertBtn.addEventListener("click", () => {
		if (!dateInput.value) {
			dateResult.textContent = "请选择日期时间。";
			return;
		}
		const date = new Date(dateInput.value);
		dateResult.innerHTML = `秒级：<strong>${Math.floor(date.getTime() / 1000)}</strong><br>毫秒级：<strong>${date.getTime()}</strong><br>本地时间：<strong>${date.toLocaleString()}</strong>`;
	});

	renderNow();
	setInterval(renderNow, 1000);
</script>
