---
import ToolPage from "@/components/tools/ToolPage.astro";
---

<ToolPage
	title="图片压缩"
	description="在浏览器本地压缩图片，支持导出 WebP、JPG 和 PNG。"
	icon="material-symbols:image"
>
	<div class="grid grid-cols-1 xl:grid-cols-[1fr_360px] gap-4">
		<section class="rounded-lg border border-(--line-divider) bg-(--card-bg) p-4">
			<h2 class="mb-3 text-lg font-bold text-neutral-900 dark:text-neutral-100">选择图片</h2>
			<label
				for="image-file"
				class="flex min-h-52 cursor-pointer flex-col items-center justify-center rounded-lg border border-dashed border-(--line-divider) bg-(--btn-regular-bg) px-4 py-8 text-center transition hover:border-(--primary)"
			>
				<span class="text-base font-bold text-neutral-900 dark:text-neutral-100">点击选择图片</span>
				<span class="mt-2 text-sm text-neutral-500 dark:text-neutral-400">支持 PNG、JPG、WebP 等常见图片格式</span>
				<input id="image-file" type="file" accept="image/*" class="hidden" />
			</label>

			<div class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-3">
				<label class="text-sm font-medium text-neutral-700 dark:text-neutral-300">
					导出格式
					<select id="image-format" class="tool-input mt-1">
						<option value="image/webp" selected>WebP</option>
						<option value="image/jpeg">JPG</option>
						<option value="image/png">PNG</option>
					</select>
				</label>
				<label class="text-sm font-medium text-neutral-700 dark:text-neutral-300">
					质量
					<input id="image-quality" type="range" min="0.1" max="1" step="0.05" value="0.82" class="mt-3 w-full" />
					<span id="quality-label" class="mt-1 block text-xs text-neutral-500">82%</span>
				</label>
				<label class="text-sm font-medium text-neutral-700 dark:text-neutral-300">
					最大宽度
					<input id="image-max-width" type="number" min="100" max="8000" value="1920" class="tool-input mt-1" />
				</label>
			</div>

			<div class="mt-4 flex flex-wrap gap-3">
				<button id="image-compress" class="btn-regular rounded-lg px-4 py-2 font-medium">压缩图片</button>
				<a id="image-download" class="btn-regular rounded-lg px-4 py-2 font-medium pointer-events-none opacity-50" download="compressed.webp">下载图片</a>
			</div>

			<div id="image-status" class="mt-4 rounded-lg bg-(--btn-regular-bg) px-4 py-3 text-sm text-neutral-600 dark:text-neutral-300">
				请选择一张图片。
			</div>
		</section>

		<section class="rounded-lg border border-(--line-divider) bg-(--card-bg) p-4">
			<h2 class="mb-3 text-lg font-bold text-neutral-900 dark:text-neutral-100">预览</h2>
			<div class="aspect-square w-full overflow-hidden rounded-lg bg-(--btn-regular-bg) flex items-center justify-center">
				<img id="image-preview" class="max-h-full max-w-full object-contain" alt="" />
			</div>
			<div class="mt-4 grid grid-cols-2 gap-3 text-sm">
				<div class="rounded-lg bg-(--btn-regular-bg) p-3">
					<div class="text-neutral-500 dark:text-neutral-400">原始大小</div>
					<div id="image-original-size" class="mt-1 font-bold text-neutral-900 dark:text-neutral-100">-</div>
				</div>
				<div class="rounded-lg bg-(--btn-regular-bg) p-3">
					<div class="text-neutral-500 dark:text-neutral-400">压缩后</div>
					<div id="image-output-size" class="mt-1 font-bold text-neutral-900 dark:text-neutral-100">-</div>
				</div>
			</div>
		</section>
	</div>
</ToolPage>

<style>
	.tool-input {
		width: 100%;
		border-radius: 0.75rem;
		border: 1px solid var(--line-divider);
		background: color-mix(in srgb, var(--card-bg) 90%, transparent);
		padding: 0.75rem 1rem;
		outline: none;
	}
	.tool-input:focus {
		border-color: var(--primary);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 18%, transparent);
	}
</style>

<script>
	const fileInput = document.querySelector<HTMLInputElement>("#image-file")!;
	const formatInput = document.querySelector<HTMLSelectElement>("#image-format")!;
	const qualityInput = document.querySelector<HTMLInputElement>("#image-quality")!;
	const maxWidthInput = document.querySelector<HTMLInputElement>("#image-max-width")!;
	const qualityLabel = document.querySelector<HTMLElement>("#quality-label")!;
	const preview = document.querySelector<HTMLImageElement>("#image-preview")!;
	const status = document.querySelector<HTMLElement>("#image-status")!;
	const originalSize = document.querySelector<HTMLElement>("#image-original-size")!;
	const outputSize = document.querySelector<HTMLElement>("#image-output-size")!;
	const download = document.querySelector<HTMLAnchorElement>("#image-download")!;
	const compressBtn = document.querySelector<HTMLButtonElement>("#image-compress")!;
	let currentFile: File | null = null;
	let currentObjectUrl = "";

	function formatBytes(bytes: number): string {
		if (!bytes) return "0 B";
		const units = ["B", "KB", "MB", "GB"];
		const index = Math.min(Math.floor(Math.log(bytes) / Math.log(1024)), units.length - 1);
		return `${(bytes / 1024 ** index).toFixed(index === 0 ? 0 : 1)} ${units[index]}`;
	}

	function setStatus(message: string, ok = true) {
		status.textContent = message;
		status.classList.toggle("text-red-600", !ok);
		status.classList.toggle("dark:text-red-400", !ok);
	}

	function setDownload(blob: Blob, format: string) {
		if (currentObjectUrl) URL.revokeObjectURL(currentObjectUrl);
		currentObjectUrl = URL.createObjectURL(blob);
		download.href = currentObjectUrl;
		download.download = `compressed.${format.split("/")[1].replace("jpeg", "jpg")}`;
		download.classList.remove("pointer-events-none", "opacity-50");
		preview.src = currentObjectUrl;
	}

	fileInput.addEventListener("change", () => {
		const file = fileInput.files?.[0];
		if (!file) return;
		currentFile = file;
		preview.src = URL.createObjectURL(file);
		originalSize.textContent = formatBytes(file.size);
		outputSize.textContent = "-";
		setStatus(`已选择：${file.name}`);
	});

	qualityInput.addEventListener("input", () => {
		qualityLabel.textContent = `${Math.round(Number(qualityInput.value) * 100)}%`;
	});

	compressBtn.addEventListener("click", async () => {
		const sourceFile = currentFile;
		if (!sourceFile) return setStatus("请先选择图片。", false);
		try {
			const bitmap = await createImageBitmap(sourceFile);
			const maxWidth = Math.max(100, Number(maxWidthInput.value) || bitmap.width);
			const scale = Math.min(1, maxWidth / bitmap.width);
			const width = Math.round(bitmap.width * scale);
			const height = Math.round(bitmap.height * scale);
			const canvas = document.createElement("canvas");
			canvas.width = width;
			canvas.height = height;
			const ctx = canvas.getContext("2d");
			if (!ctx) throw new Error("浏览器不支持 Canvas。");
			ctx.drawImage(bitmap, 0, 0, width, height);
			const format = formatInput.value;
			const quality = Number(qualityInput.value);
			canvas.toBlob(
				(blob) => {
					if (!blob) return setStatus("图片导出失败。", false);
					setDownload(blob, format);
					outputSize.textContent = formatBytes(blob.size);
					const ratio = ((1 - blob.size / sourceFile.size) * 100).toFixed(1);
					setStatus(`压缩完成：${bitmap.width}x${bitmap.height} -> ${width}x${height}，体积减少 ${ratio}%。`);
				},
				format,
				format === "image/png" ? undefined : quality,
			);
		} catch (error) {
			setStatus(error instanceof Error ? error.message : "图片处理失败。", false);
		}
	});
</script>
