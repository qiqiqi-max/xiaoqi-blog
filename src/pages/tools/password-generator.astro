---
import ToolPage from "@/components/tools/ToolPage.astro";
---

<ToolPage
	title="密码生成器"
	description="生成随机强密码，可自定义长度、字符类型和数量。"
	icon="material-symbols:password"
>
	<div class="grid grid-cols-1 xl:grid-cols-[360px_1fr] gap-4">
		<section class="rounded-lg border border-(--line-divider) bg-(--card-bg) p-4">
			<h2 class="mb-4 text-lg font-bold text-neutral-900 dark:text-neutral-100">设置</h2>
			<label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300">
				长度：<span id="password-length-label">20</span>
				<input id="password-length" type="range" min="6" max="64" value="20" class="mt-3 w-full" />
			</label>
			<label class="mt-4 block text-sm font-medium text-neutral-700 dark:text-neutral-300">
				生成数量
				<input id="password-count" type="number" min="1" max="50" value="8" class="tool-input mt-1" />
			</label>
			<div class="mt-4 grid grid-cols-1 gap-2 text-sm">
				<label class="tool-check"><input type="checkbox" id="use-lower" checked /> 小写字母</label>
				<label class="tool-check"><input type="checkbox" id="use-upper" checked /> 大写字母</label>
				<label class="tool-check"><input type="checkbox" id="use-number" checked /> 数字</label>
				<label class="tool-check"><input type="checkbox" id="use-symbol" checked /> 符号</label>
				<label class="tool-check"><input type="checkbox" id="exclude-ambiguous" checked /> 排除易混淆字符</label>
			</div>
			<div class="mt-4 flex flex-wrap gap-3">
				<button id="password-generate" class="btn-regular rounded-lg px-4 py-2 font-medium">生成密码</button>
				<button id="password-copy" class="btn-regular rounded-lg px-4 py-2 font-medium">复制全部</button>
			</div>
		</section>

		<section class="rounded-lg border border-(--line-divider) bg-(--card-bg) p-4">
			<h2 class="mb-3 text-lg font-bold text-neutral-900 dark:text-neutral-100">结果</h2>
			<textarea id="password-output" class="tool-textarea min-h-96" readonly></textarea>
			<div id="password-status" class="mt-4 rounded-lg bg-(--btn-regular-bg) px-4 py-3 text-sm text-neutral-600 dark:text-neutral-300">
				点击生成密码。
			</div>
		</section>
	</div>
</ToolPage>

<style>
	.tool-input,
	.tool-textarea {
		width: 100%;
		border-radius: 0.75rem;
		border: 1px solid var(--line-divider);
		background: color-mix(in srgb, var(--card-bg) 90%, transparent);
		padding: 0.75rem 1rem;
		outline: none;
	}
	.tool-textarea {
		resize: vertical;
		font-family: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		line-height: 1.7;
	}
	.tool-input:focus,
	.tool-textarea:focus {
		border-color: var(--primary);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 18%, transparent);
	}
	.tool-check {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
</style>

<script>
	const lengthInput = document.querySelector<HTMLInputElement>("#password-length")!;
	const lengthLabel = document.querySelector<HTMLElement>("#password-length-label")!;
	const countInput = document.querySelector<HTMLInputElement>("#password-count")!;
	const output = document.querySelector<HTMLTextAreaElement>("#password-output")!;
	const status = document.querySelector<HTMLElement>("#password-status")!;
	const lowerInput = document.querySelector<HTMLInputElement>("#use-lower")!;
	const upperInput = document.querySelector<HTMLInputElement>("#use-upper")!;
	const numberInput = document.querySelector<HTMLInputElement>("#use-number")!;
	const symbolInput = document.querySelector<HTMLInputElement>("#use-symbol")!;
	const ambiguousInput = document.querySelector<HTMLInputElement>("#exclude-ambiguous")!;
	const generateBtn = document.querySelector<HTMLButtonElement>("#password-generate")!;
	const copyBtn = document.querySelector<HTMLButtonElement>("#password-copy")!;

	const sets = {
		lower: "abcdefghijklmnopqrstuvwxyz",
		upper: "ABCDEFGHIJKLMNOPQRSTUVWXYZ",
		number: "0123456789",
		symbol: "!@#$%^&*()_+-=[]{}|;:,.<>?",
	};
	const ambiguous = /[Il1O0o]/g;

	function randomInt(max: number): number {
		const array = new Uint32Array(1);
		crypto.getRandomValues(array);
		return (array[0] ?? 0) % max;
	}

	function buildCharset(): string {
		const selected: string[] = [];
		if (lowerInput.checked) selected.push(sets.lower);
		if (upperInput.checked) selected.push(sets.upper);
		if (numberInput.checked) selected.push(sets.number);
		if (symbolInput.checked) selected.push(sets.symbol);
		let charset = selected.join("");
		if (ambiguousInput.checked) charset = charset.replace(ambiguous, "");
		return charset;
	}

	function generateOne(length: number, charset: string): string {
		let result = "";
		for (let i = 0; i < length; i++) result += charset[randomInt(charset.length)];
		return result;
	}

	function generate() {
		const charset = buildCharset();
		if (!charset) {
			status.textContent = "请至少选择一种字符类型。";
			return;
		}
		const length = Number(lengthInput.value);
		const count = Math.max(1, Math.min(50, Number(countInput.value) || 8));
		output.value = Array.from({ length: count }, () => generateOne(length, charset)).join("\n");
		status.textContent = `已生成 ${count} 个 ${length} 位密码。`;
	}

	lengthInput.addEventListener("input", () => {
		lengthLabel.textContent = lengthInput.value;
	});
	generateBtn.addEventListener("click", generate);
	copyBtn.addEventListener("click", async () => {
		if (!output.value) generate();
		await navigator.clipboard.writeText(output.value);
		status.textContent = "已复制全部密码。";
	});
	generate();
</script>
