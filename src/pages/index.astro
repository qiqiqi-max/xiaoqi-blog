---
import EntryCard from "@/components/EntryCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPublishedBlog, getPublishedNotes, getPublishedProjects, getPublishedTools } from "@/lib/content";
import { site } from "@/lib/site";

const [posts, notes, projects, tools] = await Promise.all([
  getPublishedBlog(),
  getPublishedNotes(),
  getPublishedProjects(),
  getPublishedTools()
]);
const latest = [...posts, ...notes, ...projects, ...tools]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
const hrefMap: Record<string, string> = {
  blog: "blog",
  notes: "notes",
  projects: "projects",
  tools: "tools"
};
const collectionLabels: Record<string, string> = {
  blog: "博客",
  notes: "笔记",
  projects: "项目",
  tools: "工具箱"
};
const modules = [
  {
    index: "01",
    title: "博客",
    label: "正式文章",
    href: "/blog",
    count: posts.length,
    description: "长期观点、技术复盘和完整教程。",
    emoji: "📝"
  },
  {
    index: "02",
    title: "笔记",
    label: "短记录",
    href: "/notes",
    count: notes.length,
    description: "排障过程、命令片段和临时想法。",
    emoji: "🗒️"
  },
  {
    index: "03",
    title: "项目",
    label: "作品档案",
    href: "/projects",
    count: projects.length,
    description: "目标、技术栈、进展和复盘记录。",
    emoji: "🚀"
  },
  {
    index: "04",
    title: "工具箱",
    label: "效率入口",
    href: "/tools",
    count: tools.length,
    description: "常用软件、脚本、链接和工作流。",
    emoji: "🛠️"
  }
];
---

<BaseLayout title="首页" description={site.description}>

  <!-- ① Hero Banner -->
  <section class="container py-10 md:py-14">
    <div class="hero-banner">
      <div class="hero-banner__text">
        <p class="hero-kicker">AI 驱动的个人知识中枢</p>
        <h1 class="hero-title">小七的<br/>长期知识系统</h1>
        <p class="hero-copy">
          用静态站承载长期知识，把博客、笔记、项目和工具沉淀成一个可搜索、可迁移、可持续扩展的个人系统。
        </p>
        <div class="hero-actions">
          <a href="/studio" class="button-primary">✏️ 添加内容</a>
          <a href="/search" class="button-secondary">🔍 搜索知识库</a>
        </div>
      </div>
      <aside class="hero-banner__stats" aria-label="站点概览">
        <dl class="stat-card surface">
          <dt>内容资产</dt>
          <dd>{posts.length + notes.length + projects.length + tools.length}<small>条记录</small></dd>
        </dl>
        <dl class="stat-card surface">
          <dt>发布方式</dt>
          <dd>静态<small>Jamstack</small></dd>
        </dl>
        <dl class="stat-card surface">
          <dt>站内搜索</dt>
          <dd>全文<small>Pagefind</small></dd>
        </dl>
        <dl class="stat-card surface">
          <dt>AI 流程</dt>
          <dd>增强<small>构建期</small></dd>
        </dl>
      </aside>
    </div>
  </section>

  <!-- ② Module Strip 功能入口 -->
  <section class="container py-6" aria-labelledby="modules-title">
    <div class="section-head">
      <div>
        <h2 id="modules-title">功能入口</h2>
        <p>四个核心内容区，从首页直接跳入对应工作台。</p>
      </div>
      <a href="/tags" class="text-link">按标签浏览 →</a>
    </div>
    <div class="module-grid">
      {modules.map((item) => (
        <a href={item.href} class="module-card">
          <div class="module-card__top">
            <span class="module-card__emoji">{item.emoji}</span>
            <span class="module-card__count">{item.count} 条</span>
          </div>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
          <div class="module-card__footer">
            <span class="module-card__label">{item.label}</span>
            <span class="module-card__arrow">→</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ③ 最新内容 -->
  <section class="container py-6">
    <div class="section-head">
      <div>
        <h2>最新更新</h2>
        <p>最近沉淀的文章、笔记和项目记录。</p>
      </div>
      <a href="/search" class="text-link">全站搜索 →</a>
    </div>
    <div class="content-grid">
      {latest.map((entry) => {
        const tags = "stack" in entry.data && entry.data.stack.length ? entry.data.stack : entry.data.tags;
        return (
          <EntryCard
            href={`/${hrefMap[entry.collection]}/${entry.id}`}
            title={entry.data.title}
            description={entry.data.description}
            date={entry.data.date}
            tags={tags}
            kind={collectionLabels[entry.collection]}
          />
        );
      })}
    </div>
  </section>

</BaseLayout>
