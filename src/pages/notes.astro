---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { formatDateToYYYYMMDD } from "@/utils/date-utils";
import { removeFileExtension, url } from "@/utils/url-utils";

const notes = await getCollection("notes", ({ data }) => {
	return import.meta.env.PROD ? data.draft !== true : true;
});

const sortedNotes = notes.sort((a, b) => {
	const dateA = new Date(a.data.published);
	const dateB = new Date(b.data.published);
	return dateA > dateB ? -1 : 1;
});
---

<MainGridLayout title="随手记" description="一些即时的小笔记、小想法和零碎记录。">
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
      <div class="mb-6">
        <div class="flex items-center gap-3 mb-3">
          <div class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70">
            <Icon is:inline name="material-symbols:edit-note" class="text-[1.5rem]" />
          </div>
          <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
            随手记
          </div>
        </div>
        <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed">
          一些即时的小笔记、小想法和零碎记录。
        </p>
      </div>

      {sortedNotes.length > 0 ? (
        <div class="grid grid-cols-1 gap-3">
          {sortedNotes.map((note) => (
            <a
              href={url(`/notes/${removeFileExtension(note.id)}/`)}
              class="group rounded-lg border border-(--line-divider) bg-(--card-bg) px-4 py-3 hover:border-(--primary) hover:bg-(--btn-card-bg-hover) transition-all duration-200"
            >
              <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                <div class="min-w-0">
                  <div class="text-lg font-bold text-neutral-900 dark:text-neutral-100 group-hover:text-(--primary) transition-colors">
                    {note.data.title}
                  </div>
                  {note.data.description && (
                    <p class="mt-1 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
                      {note.data.description}
                    </p>
                  )}
                </div>
                <time class="shrink-0 text-xs font-medium text-neutral-400 dark:text-neutral-500 pt-1">
                  {formatDateToYYYYMMDD(note.data.published)}
                </time>
              </div>
              {note.data.tags.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-2">
                  {note.data.tags.map((tag) => (
                    <span class="rounded-md bg-(--btn-regular-bg) px-2 py-1 text-xs font-medium text-(--btn-content)">
                      #{tag}
                    </span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center py-16 text-neutral-400 dark:text-neutral-500">
          <Icon is:inline name="material-symbols:edit-note" class="text-6xl mb-4 opacity-50" />
          <p class="text-lg">还没有随手记</p>
        </div>
      )}
    </div>
  </div>
</MainGridLayout>
