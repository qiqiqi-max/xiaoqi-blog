---
import { Icon } from "astro-icon/components";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

const tools = [
  {
    name: "JSON 格式化",
    description: "格式化和压缩 JSON 数据",
    icon: "material-symbols:code",
    url: "/tools/json-formatter/",
    color: "blue"
  },
  {
    name: "编码转换",
    description: "Base64、URL、Unicode、HTML 实体",
    icon: "material-symbols:swap-horiz",
    url: "/tools/encoder/",
    color: "green"
  },
  {
    name: "时间戳转换",
    description: "Unix 时间戳与日期时间互转",
    icon: "material-symbols:schedule",
    url: "/tools/timestamp/",
    color: "orange"
  },
  {
    name: "二维码生成器",
    description: "输入文字或链接生成二维码",
    icon: "material-symbols:qr-code",
    url: "/tools/qrcode/",
    color: "purple"
  },
  {
    name: "图片压缩",
    description: "压缩图片并转换为 WebP / JPG / PNG",
    icon: "material-symbols:image",
    url: "/tools/image-compressor/",
    color: "pink"
  },
  {
    name: "密码生成器",
    description: "生成随机强密码",
    icon: "material-symbols:password",
    url: "/tools/password-generator/",
    color: "red"
  },
  {
    name: "UUID 生成器",
    description: "批量生成 UUID v4",
    icon: "material-symbols:fingerprint",
    url: "/tools/uuid-generator/",
    color: "indigo"
  },
  {
    name: "文本处理",
    description: "去空行、去重复、排序、大小写转换",
    icon: "material-symbols:text-fields",
    url: "/tools/text-processor/",
    color: "teal"
  }
];

const colorClasses = {
  blue: "bg-blue-500/10 text-blue-600 dark:text-blue-400",
  green: "bg-green-500/10 text-green-600 dark:text-green-400",
  purple: "bg-purple-500/10 text-purple-600 dark:text-purple-400",
  pink: "bg-pink-500/10 text-pink-600 dark:text-pink-400",
  orange: "bg-orange-500/10 text-orange-600 dark:text-orange-400",
  red: "bg-red-500/10 text-red-600 dark:text-red-400",
  indigo: "bg-indigo-500/10 text-indigo-600 dark:text-indigo-400",
  teal: "bg-teal-500/10 text-teal-600 dark:text-teal-400"
};
---

<MainGridLayout title="工具箱" description="一些实用的在线小工具">
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
      <div class="mb-6">
        <div class="flex items-center gap-3 mb-3">
          <div class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70">
            <Icon is:inline name="material-symbols:build" class="text-[1.5rem]" />
          </div>
          <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
            工具箱
          </div>
        </div>
        <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed">
          常用的在线小工具，全部在浏览器本地运行
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
        {tools.map((tool) => (
          <a
            href={tool.url}
            class="group rounded-lg border border-(--line-divider) bg-(--card-bg) p-5 hover:border-(--primary) hover:bg-(--btn-card-bg-hover) hover:shadow-lg transition-all duration-200"
          >
            <div class="flex items-start gap-3">
              <div class={`flex-shrink-0 w-12 h-12 rounded-lg flex items-center justify-center ${colorClasses[tool.color]}`}>
                <Icon is:inline name={tool.icon} class="text-2xl" />
              </div>
              <div class="flex-1 min-w-0">
                <div class="text-lg font-bold text-neutral-900 dark:text-neutral-100 group-hover:text-(--primary) transition-colors mb-1">
                  {tool.name}
                </div>
                <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
                  {tool.description}
                </p>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-8 pt-6 border-t border-(--line-divider)">
        <p class="text-sm text-center text-neutral-500 dark:text-neutral-400">
          所有工具均为纯前端处理，输入内容不会上传到服务器
        </p>
      </div>
    </div>
  </div>
</MainGridLayout>
