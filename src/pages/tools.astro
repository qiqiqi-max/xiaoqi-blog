---
import CollectionOverview from "@/components/CollectionOverview.astro";
import EntryCard from "@/components/EntryCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPublishedTools } from "@/lib/content";

const tools = await getPublishedTools();
const externalCount = tools.filter((tool) => Boolean(tool.data.link)).length;
const tagCount = new Set(tools.flatMap((tool) => tool.data.tags)).size;
---

<BaseLayout title="工具箱" description="常用软件、链接、脚本和个人工具箱。">
  <section class="container">
    <header class="page-head">
      <div>
        <h1>工具箱</h1>
        <p>常用软件、链接、脚本、排障入口和个人工作流记录。</p>
      </div>
      <div class="page-actions">
        <a class="button-primary" href="/studio?type=tools">添加工具</a>
        <a class="button-secondary" href="/search">搜索工具</a>
      </div>
    </header>
    <CollectionOverview
      eyebrow="效率入口区"
      title="把常用软件、脚本和链接收进一个稳定入口"
      description="工具箱模块用来记录软件迁移位置、启动方式、脚本命令、常用链接和个人工作流。以后桌面上不该散落的东西，都可以归档到这里。"
      ctaHref="/notes"
      ctaLabel="查看排障笔记"
      metrics={[
        { label: "工具数量", value: `${tools.length} 个`, note: "软件和工作流" },
        { label: "外部入口", value: `${externalCount} 个`, note: "可直接跳转" },
        { label: "标签覆盖", value: `${tagCount} 个`, note: "按用途归类" }
      ]}
    />
    <div class="content-grid py-8">
      {tools.map((tool) => (
        <EntryCard href={tool.data.link || `/tools/${tool.id}`} title={tool.data.title} description={tool.data.description} date={tool.data.date} tags={tool.data.tags} />
      ))}
    </div>
  </section>
</BaseLayout>
