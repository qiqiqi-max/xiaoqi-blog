---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { navItems, site } from "@/lib/site";

type Props = {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: Date | string;
  modifiedTime?: Date | string;
  tags?: string[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  pagefind?: {
    filters?: Record<string, string | string[] | undefined>;
    meta?: Record<string, string | undefined>;
    sorts?: Record<string, string | undefined>;
  };
};

const {
  title,
  description = site.description,
  image = "/og/default.svg",
  type = "website",
  publishedTime,
  modifiedTime,
  tags = [],
  jsonLd,
  pagefind
} = Astro.props;
const pageTitle = title ? `${title} | ${site.name}` : site.name;
const canonical = new URL(Astro.url.pathname, site.url).toString();
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath === href || currentPath.startsWith(`${href}/`);
const navClass = (href: string) =>
  [
    "rounded-md px-3 py-2 text-sm transition whitespace-nowrap",
    isActive(href)
      ? "bg-teal-700 text-white dark:bg-teal-300 dark:text-slate-950"
      : "text-[var(--muted)] hover:bg-black/5 hover:text-[var(--text)] dark:hover:bg-white/5"
  ].join(" ");
const searchClass = [
  "rounded-md border px-3 py-2 text-sm transition whitespace-nowrap",
  currentPath === "/search"
    ? "border-teal-600 bg-teal-700 text-white dark:border-teal-300 dark:bg-teal-300 dark:text-slate-950"
    : "border-[var(--border)] text-[var(--muted)] hover:text-[var(--text)]"
].join(" ");

const pagefindFilters = Object.entries(pagefind?.filters ?? {}).flatMap(([key, value]) => {
  const values = Array.isArray(value) ? value : [value];
  return values.filter(Boolean).map((item) => ({ key, value: item as string }));
});
const pagefindMeta = Object.entries(pagefind?.meta ?? {}).filter((entry): entry is [string, string] =>
  Boolean(entry[1])
);
const pagefindSorts = Object.entries(pagefind?.sorts ?? {}).filter((entry): entry is [string, string] =>
  Boolean(entry[1])
);
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const isoDate = (value?: Date | string) => (value ? new Date(value).toISOString() : undefined);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0f766e" />
    <link rel="canonical" href={canonical} />
    {pagefindFilters.map((item) => <meta data-pagefind-filter={`${item.key}[content]`} content={item.value} />)}
    {pagefindMeta.map(([key, value]) => <meta data-pagefind-meta={`${key}[content]`} content={value} />)}
    {pagefindSorts.map(([key, value]) => <meta data-pagefind-sort={`${key}[content]`} content={value} />)}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, site.url).toString()} />
    {publishedTime && <meta property="article:published_time" content={isoDate(publishedTime)} />}
    {modifiedTime && <meta property="article:modified_time" content={isoDate(modifiedTime)} />}
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="alternate" type="application/rss+xml" title={site.name} href="/rss.xml" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {jsonLdItems.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}
    <ClientRouter />
    <script is:inline>
      (() => {
        try {
          const savedTheme = localStorage.getItem("theme");
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          if (savedTheme === "dark" || (!savedTheme && prefersDark)) {
            document.documentElement.classList.add("dark");
          }
        } catch {
          if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
        }
      })();
    </script>
  </head>
  <body>
    <div id="reading-progress" aria-hidden="true"></div>
    <a href="#main" class="skip-link">跳到正文</a>
    <header class="container py-5">
      <nav class="surface rounded-lg px-4 py-3" aria-label="主导航">
        <div class="flex items-center justify-between gap-4">
          <a href="/" class="flex items-center gap-3 font-semibold" aria-label={`${site.name}首页`}>
            <span class="grid h-9 w-9 place-items-center rounded-md bg-teal-700 text-white">七</span>
            <span class="hidden sm:inline">{site.name}</span>
          </a>
          <div class="hidden items-center gap-1 md:flex">
            {navItems.map((item) => (
              <a class={navClass(item.href)} href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
                {item.label}
              </a>
            ))}
          </div>
          <div class="flex items-center gap-2">
            <a href="/search" class={searchClass} aria-current={currentPath === "/search" ? "page" : undefined}>
              搜索
            </a>
            <button
              id="theme-toggle"
              class="h-10 rounded-md border border-[var(--border)] px-3 text-sm text-[var(--muted)] transition hover:text-[var(--text)]"
              aria-label="切换主题"
              aria-pressed="false"
            >
              主题
            </button>
          </div>
        </div>
        <div class="mt-3 flex flex-wrap gap-2 pb-1 md:hidden">
          {navItems.map((item) => (
            <a class={navClass(item.href)} href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
              {item.label}
            </a>
          ))}
        </div>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="container py-10 text-sm text-[var(--muted)]">
      <div class="border-t border-[var(--border)] pt-6">
        <p>{site.name} · 为长期写作、静态部署和 AI 辅助创作而建。</p>
      </div>
    </footer>
    <script is:inline>
      const themeButton = document.getElementById("theme-toggle");
      const syncThemeButton = () => {
        if (!themeButton) return;
        const isDark = document.documentElement.classList.contains("dark");
        themeButton.textContent = isDark ? "深色" : "浅色";
        themeButton.setAttribute("aria-pressed", isDark ? "true" : "false");
        themeButton.setAttribute("title", isDark ? "切换到浅色模式" : "切换到深色模式");
      };
      syncThemeButton();
      themeButton?.addEventListener("click", () => {
        const isDark = document.documentElement.classList.toggle("dark");
        try {
          localStorage.setItem("theme", isDark ? "dark" : "light");
        } catch {}
        syncThemeButton();
      });

      const progressBar = document.getElementById("reading-progress");
      const syncReadingProgress = () => {
        if (!progressBar) return;
        const scrollable = document.documentElement.scrollHeight - window.innerHeight;
        const ratio = scrollable > 0 ? window.scrollY / scrollable : 0;
        progressBar.style.transform = `scaleX(${Math.min(1, Math.max(0, ratio))})`;
      };
      syncReadingProgress();
      window.addEventListener("scroll", syncReadingProgress, { passive: true });
      window.addEventListener("resize", syncReadingProgress);
    </script>
  </body>
</html>
