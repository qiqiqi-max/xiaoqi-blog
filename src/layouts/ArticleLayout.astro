---
import BaseLayout from "./BaseLayout.astro";
import { formatDate, readingTime, slugifyTag, site } from "@/lib/site";

type Heading = {
  depth: number;
  slug: string;
  text: string;
};

type Props = {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  tags?: string[];
  category?: string;
  body?: string;
  cover?: string;
  headings?: Heading[];
  section?: string;
  type?: string;
};

const {
  title,
  description,
  date,
  updated,
  tags = [],
  category,
  body = "",
  cover,
  headings = [],
  section = "文章",
  type: contentType = "article"
} = Astro.props;
const tagHref = (tag: string) => `/tags/${encodeURI(slugifyTag(tag))}`;
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const canonical = new URL(Astro.url.pathname, site.url).toString();
const imageUrl = new URL(cover ?? "/og/default.svg", site.url).toString();
const publishedIso = date.toISOString();
const updatedIso = (updated ?? date).toISOString();
const jsonLd = {
  "@context": "https://schema.org",
  "@type": contentType === "project" ? "CreativeWork" : "BlogPosting",
  headline: title,
  description,
  image: imageUrl,
  datePublished: publishedIso,
  dateModified: updatedIso,
  author: {
    "@type": "Person",
    name: site.author
  },
  publisher: {
    "@type": "Organization",
    name: site.name,
    logo: {
      "@type": "ImageObject",
      url: new URL("/favicon.svg", site.url).toString()
    }
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonical
  },
  keywords: tags.join(", ")
};
---

<BaseLayout
  title={title}
  description={description}
  image={cover}
  type="article"
  publishedTime={date}
  modifiedTime={updated ?? date}
  tags={tags}
  jsonLd={jsonLd}
  pagefind={{
    filters: {
      "栏目": section,
      "分类": category,
      "标签": tags
    },
    sorts: {
      date: String(date.valueOf())
    }
  }}
>
  <div class="article-shell py-10">
    <article class="article-main">
      <header class="mb-8">
        <div class="mb-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-[var(--muted)]">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-teal-50 text-teal-800 dark:bg-teal-900/40 dark:text-teal-300 border border-teal-100 dark:border-teal-900/60">{section}</span>
          {category && <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-slate-100 text-slate-800 dark:bg-slate-800/60 dark:text-slate-300 border border-slate-200/60 dark:border-slate-700/60">{category}</span>}
          
          <span class="flex items-center gap-1 font-medium">
            <svg class="w-4 h-4 text-teal-600 dark:text-teal-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            {formatDate(date)}
          </span>
          
          {updated && (
            <span class="flex items-center gap-1 font-medium">
              <svg class="w-4 h-4 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3 3L22 4"></path></svg>
              更新于 {formatDate(updated)}
            </span>
          )}
          
          <span class="flex items-center gap-1 font-medium">
            <svg class="w-4 h-4 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
            {readingTime(body)}
          </span>
        </div>
        <h1 class="mb-4 text-4xl font-semibold leading-tight font-display tracking-tight text-[var(--text)] md:text-5xl">{title}</h1>
        <p class="text-lg text-[var(--muted)]">{description}</p>
        {tags.length > 0 && (
          <div class="mt-5 flex flex-wrap gap-2">
            {tags.map((tag) => <a class="chip" href={tagHref(tag)} aria-label={`查看标签：${tag}`}>#{tag}</a>)}
          </div>
        )}
      </header>

      {tocHeadings.length > 0 && (
        <nav class="toc-panel toc-mobile surface" aria-label="文章目录">
          <h2>目录</h2>
          <div>
            {tocHeadings.map((heading) => (
              <a class={`toc-link depth-${heading.depth}`} href={`#${heading.slug}`}>
                {heading.text}
              </a>
            ))}
          </div>
        </nav>
      )}

      <div class="prose" data-pagefind-body>
        <slot />
      </div>
    </article>

    {tocHeadings.length > 0 && (
      <aside class="toc-desktop" data-pagefind-ignore>
        <nav class="toc-panel surface" aria-label="文章目录">
          <h2>目录</h2>
          <div>
            {tocHeadings.map((heading) => (
              <a class={`toc-link depth-${heading.depth}`} href={`#${heading.slug}`}>
                {heading.text}
              </a>
            ))}
          </div>
        </nav>
      </aside>
    )}
  </div>

  <script is:inline>
    const initCodeCopy = () => {
      document.querySelectorAll(".prose pre").forEach((pre) => {
        if (!(pre instanceof HTMLElement) || pre.dataset.copyReady === "true") return;
        const code = pre.querySelector("code");
        if (!code) return;
        pre.dataset.copyReady = "true";

        const wrapper = document.createElement("div");
        wrapper.className = "code-frame";
        pre.parentNode?.insertBefore(wrapper, pre);

        // Create header bar
        const headerBar = document.createElement("div");
        headerBar.className = "code-header-bar";

        // Create dots container
        const dots = document.createElement("div");
        dots.className = "code-header-dots";
        dots.innerHTML = '<span class="dot-red"></span><span class="dot-yellow"></span><span class="dot-green"></span>';
        headerBar.appendChild(dots);

        // Language label
        const langClass = Array.from(code.classList).find((c) => c.startsWith("language-"));
        if (langClass) {
          const langText = document.createElement("span");
          langText.className = "code-header-lang";
          langText.textContent = langClass.replace("language-", "").toUpperCase();
          headerBar.appendChild(langText);
        }

        wrapper.appendChild(headerBar);
        wrapper.appendChild(pre);

        const button = document.createElement("button");
        button.type = "button";
        button.className = "code-copy";
        button.textContent = "复制";
        button.setAttribute("aria-label", "复制代码");
        button.addEventListener("click", async () => {
          try {
            await navigator.clipboard.writeText(code.textContent ?? "");
            button.textContent = "已复制";
            window.setTimeout(() => {
              button.textContent = "复制";
            }, 1400);
          } catch {
            button.textContent = "复制失败";
            window.setTimeout(() => {
              button.textContent = "复制";
            }, 1400);
          }
        });
        wrapper.appendChild(button);
      });
    };

    const initTOCScrollSpy = () => {
      const links = document.querySelectorAll(".toc-panel .toc-link");
      const headings = Array.from(document.querySelectorAll(".prose h2, .prose h3"))
        .filter((h) => h.id);
      
      if (!links.length || !headings.length) return;

      let currentActive = null;
      const observerOptions = {
        root: null,
        rootMargin: "-100px 0px -70% 0px",
        threshold: 0
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            currentActive = entry.target.id;
            updateActiveLink();
          }
        });
      }, observerOptions);

      const updateActiveLink = () => {
        if (!currentActive) return;
        links.forEach((link) => {
          if (link.getAttribute("href") === `#${currentActive}`) {
            link.classList.add("active");
          } else {
            link.classList.remove("active");
          }
        });
      };

      headings.forEach((heading) => observer.observe(heading));
    };

    initCodeCopy();
    initTOCScrollSpy();
    document.addEventListener("astro:page-load", () => {
      initCodeCopy();
      initTOCScrollSpy();
    });
  </script>
</BaseLayout>
