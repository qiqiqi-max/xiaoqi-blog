---
import { formatDate } from "@/lib/site";

type Props = {
  href: string;
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  kind?: string;
};

const { href, title, description, date, tags = [], kind } = Astro.props;
---

<a href={href} class="entry-card group">
  <div class="entry-card__meta">
    {kind && <span class="entry-card__kind">{kind}</span>}
    <span>{formatDate(date)}</span>
    <span aria-hidden="true">/</span>
    <span>{tags[0] ?? "记录"}</span>
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
  <div class="entry-card__footer">
    <div class="flex flex-wrap gap-2">
      {tags.slice(0, 4).map((tag) => <span class="chip">#{tag}</span>)}
    </div>
    <span class="entry-card__arrow" aria-hidden="true">→</span>
  </div>
</a>
