{
  "name": "ai-driven-nexus-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "css": "tailwindcss -c tailwind.config.mjs -i ./src/styles/tailwind.input.css -o ./src/styles/generated.css --minify",
    "dev": "npm run css && astro dev",
    "studio:server": "node scripts/studio-server.mjs",
    "dev:studio": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Start-Process -WindowStyle Hidden -FilePath npm.cmd -ArgumentList 'run','studio:server'; npm run dev\"",
    "build": "npm run css && astro build && pagefind --site dist",
    "preview": "astro preview",
    "ai:process": "python scripts/ai-processor.py",
    "ai:dry-run": "python scripts/ai-processor.py --dry-run",
    "new:blog": "node scripts/new-content.mjs blog",
    "new:note": "node scripts/new-content.mjs note",
    "new:project": "node scripts/new-content.mjs project",
    "new:tool": "node scripts/new-content.mjs tool"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "7.2.0",
    "@astrojs/mdx": "6.0.2",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.3",
    "astro": "6.4.4",
    "katex": "0.16.25",
    "pagefind": "1.5.2",
    "rehype-katex": "7.0.1",
    "remark-gfm": "4.0.1",
    "remark-math": "6.0.0",
    "tailwindcss": "3.4.17",
    "typescript": "6.0.3"
  }
}
